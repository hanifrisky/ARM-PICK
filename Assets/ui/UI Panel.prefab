  m_Script: {fileID: 11500000, guid: e933f13d48c681d48b14750922ac906d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _comment: 'We use the Ignore Collisions In Children script to prevent UI elements
    from colliding with each other, which is commonly desired when building an interface.



    In
    your application, we recommend using layers instead of this script, especially
    if your UI consists of more than just a few objects. Layers will achieve the
    same results with a significant performance boost over the Physics.IgnoreCollision()
    method utilized by this script.'
  _isEditing: 0
